<div class="roll-req-chat-card">
  <header class="roll-req-header">
    <h3><i class="fas fa-dice-d20"></i> {{title}}</h3>
    <span class="roll-req-target">{{actorName}}</span>
  </header>

  {{#if gmMessage}}
  <div class="roll-req-message">
    <p>{{gmMessage}}</p>
  </div>
  {{/if}}

  <button type="button" class="roll-req-execute" data-actor-id="{{actorId}}" data-request="{{requestData}}">
    <i class="fas fa-dice"></i> {{buttonLabel}}
  </button>
</div>
